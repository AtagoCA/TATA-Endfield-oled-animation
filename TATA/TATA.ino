// Array of all bitmaps for convenience. (Total bytes used to store images in PROGMEM = 4224)
const int epd_bitmap_allArray_LEN = 8;
const unsigned char* epd_bitmap_allArray[8] = {
	epd_bitmap_Artboard_1,
	epd_bitmap_Artboard_2,
	epd_bitmap_Artboard_3,
	epd_bitmap_Artboard_4,
	epd_bitmap_Artboard_5,
	epd_bitmap_Artboard_6,
	epd_bitmap_Artboard_7,
	epd_bitmap_Artboard_8
};

const int totalFrames = sizeof(epd_bitmap_allArray) / sizeof(epd_bitmap_allArray[0]);
int lastIndex = -1;

unsigned long previousMillis = 0;
const unsigned long interval = random(500, 3000);   // animation speed (ms)


void setup() 
{
  Serial.begin(9600);
  Serial.println("Originium Environment Assesment Tools");

  // SSD1306_SWITCHCAPVCC = generate display voltage from 3.3V internally
  if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
    Serial.println(F("Terminal display failed"));
    for(;;); // Don't proceed, loop forever
  }
  
  Serial.println("Terminal display innitialized");
	display.ssd1306_command(SSD1306_SETCONTRAST);
	display.ssd1306_command(0x00);  // Lower = dimmer (0x00–0xFF)
	display.dim(true);
  display.clearDisplay();
  delay(1000);
  // Clear the buffer.


}


void loop() {

	unsigned long currentTime = millis();

  if (currentTime - previousMillis >= interval) {

    previousMillis = currentTime;

		int randomIndex;

		do {
			randomIndex = random(epd_bitmap_allArray_LEN);
		} while (randomIndex == lastIndex);

		lastIndex = randomIndex;

		const unsigned char* selectedBitmap = epd_bitmap_allArray[randomIndex];

		display.drawBitmap(
		0, 
		0, 
		selectedBitmap, 
		128, 
		32, 
		SSD1306_WHITE   // <-- REQUIRED
		);
		display.display();
		display.clearDisplay();
	}
}